  },
  "devDependencies": {
    "@nuxt/eslint": "^1.13.0",
    "@types/node": "^25.0.10",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unicorn": "^62.0.0",
    "eslint-plugin-unused-imports": "^4.3.0",
    "prettier": "^3.8.1"
  }
}
